# ── Python Standard ──────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/

# ── Environments ─────────────────────────────────────────────────────────────
.venv/
env/
venv/

# ── Secrets & Configurations ─────────────────────────────────────────────────
.env
!.env.example

# ── Project Specific (RAG Assistant) ─────────────────────────────────────────
# data/vector_db/ is intentionally tracked — committed to repo so HF Spaces
# has the pre-built Chroma index on cold start (no re-ingest needed).

# Ignore ephemeral session directories and temporary files
temp/

# Ignore Gradio flagged uploads (if flagging is ever enabled)
flagged/

# ── IDEs & OS ────────────────────────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
*.swp
*.swo

# ─────────────────────────────────────────────────────────────────────────────
# AI Expert Assistant — Environment Configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Server ───────────────────────────────────────────────────────────────
# Point to any OpenAI-compatible API (LM Studio, Ollama, OpenAI, etc.)
LM_STUDIO_BASE=http://127.0.0.1:1234/v1
LM_MODEL=local-model
OPENAI_API_KEY=lm-studio

# For real OpenAI API, set:
# LM_STUDIO_BASE=https://api.openai.com/v1
# LM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...

# ── Embeddings ────────────────────────────────────────────────────────────────
# Optional: path to local HuggingFace model cache
# HF_HOME=C:\Users\<you>\.cache\huggingface

# ── Evaluation ────────────────────────────────────────────────────────────────
# Set to false to skip LLM-as-judge evaluation (retrieval metrics still work)
AI_EVAL_ENABLED=true
